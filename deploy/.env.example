# Server address: domain name or leave empty to auto-detect IP
# With domain: enables Caddy auto-HTTPS + all transports
# Without domain: use IP directly with H3/Reality transports
SHUTTLE_DOMAIN=

# Authentication password for clients (auto-generated if empty)
SHUTTLE_PASSWORD=

# Transport protocol: h3, reality, or both (default: both)
SHUTTLE_TRANSPORT=both

# Email for Let's Encrypt certificate (only needed when using a domain + Caddy)
SHUTTLE_EMAIL=

# Admin panel token (auto-generated if empty)
SHUTTLE_ADMIN_TOKEN=

# Enable debug logging
SHUTTLE_DEBUG=false
