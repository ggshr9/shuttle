# Required: Your domain pointing to this server (DNS A record)
SHUTTLE_DOMAIN=proxy.example.com

# Required: Authentication password for clients
SHUTTLE_PASSWORD=change-me-to-a-strong-password

# Required: Email for Let's Encrypt certificate
SHUTTLE_EMAIL=admin@example.com

# Optional: Admin panel token (auto-generated if empty)
SHUTTLE_ADMIN_TOKEN=

# Optional: Enable debug logging
SHUTTLE_DEBUG=false
