          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "shuttle_active_streams",
          "legendFormat": "Active Streams",
          "refId": "A"
        }
