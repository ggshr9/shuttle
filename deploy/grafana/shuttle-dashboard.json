{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "shuttle_active_connections",
          "legendFormat": "Active Connections",
          "refId": "A"
        },
        {
          "expr": "rate(shuttle_connections_total[5m])",
          "legendFormat": "New Connections/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Bandwidth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(shuttle_bytes_received_total[5m])",
          "legendFormat": "Bytes In/s",
          "refId": "A"
        },
        {
          "expr": "rate(shuttle_bytes_sent_total[5m])",
          "legendFormat": "Bytes Out/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Connection Duration Histogram",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "calculate": false,
        "yAxis": {
          "unit": "s"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges"
        },
        "cellGap": 1
      },
      "targets": [
        {
          "expr": "rate(shuttle_connection_duration_seconds_bucket[5m])",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "title": "Transport Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "shuttle_transport_active_connections",
          "legendFormat": "{{transport}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Auth Failures",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "shuttle_auth_failures_total",
          "legendFormat": "Auth Failures",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Server Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "targets": [
        {
          "expr": "shuttle_uptime_seconds",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
