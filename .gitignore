# Build output
dist/
# Re-include gui/web/dist/ but keep its build output ignored — we track a
# single .gitkeep so `//go:embed all:web/dist` has at least one file to
# match on clean checkouts. Release builds regenerate real assets via
# `npm run build` before `go build`.
!gui/web/dist/
gui/web/dist/*
!gui/web/dist/.gitkeep
*.exe
*.aar
*.xcframework
/shuttle
/shuttled
/shuttle-gui
*.deb
*.rpm
*.apk
*.ipk
*.dmg
*.pkg
*.msi

# Frontend
gui/web/node_modules/
docs/site/node_modules/
docs/site/.vitepress/dist/
docs/site/.vitepress/cache/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# GoReleaser
/dist/

# Test binaries
*.test
test/cloud/bin/
test/cloud/logs/
test/cloud/pids/

# Worktrees
.worktrees/
.superpowers/

# Local tool state (Claude Code, Playwright, etc.)
.claude/
gui/web/test-results/
gui/web/playwright-report/
