[Unit]
Description=Shuttle Proxy Client
Documentation=https://github.com/shuttle-proxy/shuttle
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/shuttle run -c /etc/shuttle/client.yaml
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/etc/shuttle
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
