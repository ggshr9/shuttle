[Unit]
Description=Shuttle Proxy Server
Documentation=https://github.com/shuttle-proxy/shuttle
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/shuttled run -c /etc/shuttle/server.yaml
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/etc/shuttle
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
